<Window x:Class="ContractManager.Views.SignatureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="契約同意 - 署名" 
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Instructions -->
        <TextBlock Grid.Row="0" 
                   Text="契約に同意するには、以下の情報を入力してください"
                   Style="{StaticResource PageSubheader}"
                   Margin="0,0,0,24"/>
        
        <!-- Name English -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="氏名（英語表記）" Style="{StaticResource FormLabel}"/>
            <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}"/>
        </StackPanel>
        
        <!-- Birth Date -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="生年月日" Style="{StaticResource FormLabel}"/>
            <DatePicker x:Name="BirthDatePicker"/>
        </StackPanel>
        
        <!-- Signature Canvas -->
        <StackPanel Grid.Row="3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="手書きサイン" Style="{StaticResource FormLabel}"/>
                <Button Grid.Column="1" Content="クリア" 
                        FontSize="12" Padding="8,4"
                        Click="ClearSignature_Click"/>
            </Grid>
            <Border BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8"
                    Background="White">
                <InkCanvas x:Name="SignatureCanvas" 
                           Height="150"
                           Background="Transparent">
                    <InkCanvas.DefaultDrawingAttributes>
                        <DrawingAttributes Color="Black" Width="2" Height="2"/>
                    </InkCanvas.DefaultDrawingAttributes>
                </InkCanvas>
            </Border>
            <TextBlock Text="上の枠内にマウスで署名してください" 
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="キャンセル" 
                    Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click"
                    Margin="0,0,8,0"/>
            <Button Content="同意して送信" 
                    Style="{StaticResource SuccessButton}"
                    Click="Submit_Click"/>
        </StackPanel>
    </Grid>
</Window>
