<UserControl x:Class="ContractManager.Views.UserDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource CardBrush}" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="契約書一覧" 
                               Style="{StaticResource PageHeader}"
                               FontSize="24"/>
                    <TextBlock x:Name="WelcomeText"
                               Style="{StaticResource PageSubheader}"
                               FontSize="14"/>
                </StackPanel>
                
                <Button Grid.Column="1" 
                        Content="ログアウト" 
                        Style="{StaticResource SecondaryButton}"
                        Click="LogoutButton_Click"/>
            </Grid>
        </Border>
        
        <!-- Contract List -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Contract List -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="紐づけ済み契約書" 
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,16"/>
                    <ListBox x:Name="ContractList"
                             BorderThickness="0"
                             SelectionChanged="ContractList_SelectionChanged"
                             Height="450">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="8">
                                    <TextBlock Text="{Binding ContractTitle}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding StatusText}" 
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
            
            <!-- Contract Detail -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="12,0,0,0">
                <Grid>
                    <Grid x:Name="DetailPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Title -->
                        <TextBlock x:Name="ContractTitle" Grid.Row="0"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,8"/>
                        
                        <!-- Status Badge -->
                        <Border x:Name="StatusBadge" Grid.Row="1"
                                CornerRadius="12"
                                Padding="12,4"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16">
                            <TextBlock x:Name="StatusText" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                        
                        <!-- Content Area -->
                        <Grid Grid.Row="2">
                            <!-- Important Contract Pre-Explanation Section -->
                            <StackPanel x:Name="ImportantContractSection" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="この契約は「重要契約」に指定されています。" FontWeight="Bold" FontSize="16" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                                <TextBlock Text="契約内容を確認するには、まず事前説明をお読みください。" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                                <Button x:Name="ViewExplanationButton" Content="事前説明を確認する" Style="{StaticResource PrimaryButton}" Click="ViewExplanation_Click" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Normal Content Section (Hidden initially if important) -->
                            <StackPanel x:Name="NormalContentSection">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="200" Margin="0,0,0,16">
                                    <TextBlock x:Name="ContractContent"
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               Foreground="{StaticResource TextBrush}"/>
                                </ScrollViewer>

                                <!-- ID Document Upload (Only visible after explanation for important contracts) -->
                                <Border x:Name="IdDocumentSection" Visibility="Collapsed" Margin="0,0,0,16" Background="#f8fafc" Padding="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Text="本人確認書類のアップロード（任意）" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBlock Text="※マイナンバーカードの裏面は撮影・アップロード禁止です" Foreground="Red" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="ファイルを選択" Click="SelectIdDocument_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="IdDocumentFileNameText" Text="未選択" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Action Buttons -->
                        <StackPanel x:Name="ActionButtons" Grid.Row="3" 
                                    Orientation="Horizontal" 
                                    Margin="0,16,0,0">
                            <Button x:Name="AgreeButton" Content="同意する" 
                                    Style="{StaticResource SuccessButton}"
                                    Click="Agree_Click"
                                    Margin="0,0,8,0"/>
                            <Button x:Name="RejectButton" Content="却下" 
                                    Style="{StaticResource DangerButton}"
                                    Click="Reject_Click"
                                    Margin="0,0,8,0"/>
                            <Button x:Name="DisputeButton" Content="異議申し立て" 
                                    Style="{StaticResource SecondaryButton}"
                                    Click="Dispute_Click"
                                    Margin="0,0,8,0"/>
                            <Button x:Name="TerminateButton" Content="契約打ち切り" 
                                    Style="{StaticResource DangerButton}"
                                    Click="Terminate_Click"
                                    Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                    
                    <TextBlock x:Name="NoSelectionText"
                               Text="左側から契約書を選択してください"
                               Style="{StaticResource PageSubheader}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
