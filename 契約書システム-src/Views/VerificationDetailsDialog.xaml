<Window x:Class="ContractManager.Views.VerificationDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="契約の検証詳細" 
        Height="650" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="契約検証データ" Style="{StaticResource PageHeader}" Margin="0,0,0,16"/>

        <!-- Audio Section -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16" x:Name="AudioSection" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="事前説明時の音声録音" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="AudioHashText" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="▶ 再生" Style="{StaticResource PrimaryButton}" Click="PlayAudio_Click" Margin="0,0,8,0"/>
                    <Button Content="■ 停止" Style="{StaticResource SecondaryButton}" Click="StopAudio_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ID Document Section -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,16" x:Name="IdDocSection" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="本人確認書類" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="※暗号化された画像データを復号して表示しています" FontSize="11" Foreground="Red" Margin="0,0,0,8"/>
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="#f8fafc" Height="300">
                    <Image x:Name="IdImage" Stretch="Uniform"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Fallback text -->
        <TextBlock x:Name="NoDataText" Grid.Row="2" Text="追加の検証データ（音声・本人確認書類）はありません" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Foreground="{StaticResource TextSecondaryBrush}"/>

        <Button Grid.Row="3" Content="閉じる" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" Click="Close_Click"/>
    </Grid>
</Window>
